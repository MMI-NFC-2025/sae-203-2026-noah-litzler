---
import { getImageUrl } from '../js/backend.mjs';

const { representation } = Astro.props;

const artiste = representation.expand?.artiste;
const scene = representation.expand?.scene;

const date = new Date(representation.date_heure);

const heure = date.toLocaleTimeString('fr-FR', {
    hour: '2-digit',
    minute: '2-digit'
});

const imageArtiste = artiste ? getImageUrl(artiste, 'photo_principale') : '';
---

<article class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm">
    <div class="flex flex-col gap-4 md:flex-row">
        {imageArtiste && (
            <img
                src={imageArtiste}
                alt={artiste.nom}
                class="h-56 w-full rounded-xl object-cover md:h-36 md:w-36"
            />
        )}

        <div class="flex-1">
            <div class="mb-3 flex flex-wrap items-center gap-2">
                <span class="rounded-full bg-black px-3 py-1 text-sm text-white">
                    {heure}
                </span>

                {scene && (
                    <span class="rounded-full bg-zinc-100 px-3 py-1 text-sm text-zinc-700">
                        {scene.nom}
                    </span>
                )}

                {artiste?.genre_musical && (
                    <span class="rounded-full bg-zinc-100 px-3 py-1 text-sm text-zinc-700">
                        {artiste.genre_musical}
                    </span>
                )}
            </div>

            <h3 class="text-2xl font-semibold text-zinc-900">
                {artiste ? artiste.nom : 'Artiste inconnu'}
            </h3>

            {scene && (
                <p class="mt-2 text-sm text-zinc-600">
                    <strong>Lieu :</strong> {scene.localisation}
                </p>
            )}

            {representation.description && (
                <p class="mt-3 text-zinc-700">
                    {representation.description}
                </p>
            )}

            {artiste && (
                <a
                    href={`/artistes/${artiste.id}`}
                    class="mt-4 inline-block text-sm font-medium text-black underline"
                >
                    Voir la fiche artiste
                </a>
            )}
        </div>
    </div>
</article>