---
import { getImageUrl } from '../js/backend.mjs';

const { representation } = Astro.props;

const artiste = representation.expand?.artiste;
const scene = representation.expand?.scene;

const date = new Date(representation.date_heure);

const heure = date.toLocaleTimeString('fr-FR', {
    hour: '2-digit',
    minute: '2-digit'
});

const imageArtiste = artiste ? getImageUrl(artiste, 'photo_principale') : '';
const genre = artiste?.genre_musical || '';
const nomScene = scene?.nom || '';
---

<article
    data-programme-item
    data-genre={genre}
    data-scene={nomScene}
    data-heure={heure}
    class="rounded-2xl border border-dark-border bg-dark-card p-4 transition hover:border-gold/40"
>
    <div class="flex flex-col gap-4 md:flex-row">
        {imageArtiste && (
            <img
                src={imageArtiste}
                alt={artiste?.nom}
                class="h-56 w-full rounded-xl object-cover md:h-36 md:w-36"
            />
        )}

        <div class="flex-1">
            <div class="mb-3 flex flex-wrap items-center gap-2">
                <span class="rounded-full bg-gold px-3 py-1 text-sm font-semibold text-dark">
                    {heure}
                </span>

                {scene && (
                    <a
                        href={`/programmes/scene/${scene.id}`}
                        class="rounded-full border border-dark-border bg-dark px-3 py-1 text-sm text-cream-muted transition hover:text-gold"
                    >
                        {scene.nom}
                    </a>
                )}

                {artiste?.genre_musical && (
                    <span class="rounded-full border border-dark-border bg-dark px-3 py-1 text-sm text-cream-muted">
                        {artiste.genre_musical}
                    </span>
                )}
            </div>

            <h3 class="font-heading text-2xl font-semibold text-cream">
                {artiste ? artiste.nom : 'Artiste inconnu'}
            </h3>

            {scene && (
                <p class="mt-2 text-sm text-cream-muted">
                    <strong class="text-gold">Lieu :</strong> {scene.localisation}
                </p>
            )}

            {representation.description && (
                <p class="mt-3 text-cream-muted">
                    {representation.description}
                </p>
            )}

            {artiste && (
                <a
                    href={`/artistes/${artiste.id}`}
                    class="mt-4 inline-block text-sm font-medium text-gold underline-offset-2 hover:underline"
                >
                    Voir la fiche artiste
                </a>
            )}
        </div>
    </div>
</article>