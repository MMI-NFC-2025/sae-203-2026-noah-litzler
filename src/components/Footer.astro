---
const annee = new Date().getFullYear();
---

<footer class="mt-20 border-t border-dark-border bg-dark-surface">
  <div class="container">

    <div class="row py-12">

      <div class="col-span-12 md:col-span-4">
        <a href="/" class="group inline-flex items-center gap-2.5">
          <span class="text-gold" aria-hidden="true">★</span>
          <span class="font-heading text-xl font-semibold text-cream transition-colors duration-200 group-hover:text-gold">
            Festicloze
          </span>
        </a>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-cream-muted">
          Festival de musique baroque et patrimoniale.<br />
          Du 20 au 23 décembre à Montbéliard.
        </p>
      </div>

      <div class="col-span-12 md:col-span-4">
        <p class="mb-4 text-xs font-semibold uppercase tracking-[0.15em] text-gold">
          Navigation
        </p>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/" class="text-cream-muted transition-colors hover:text-cream">Accueil</a></li>
          <li><a href="/festival" class="text-cream-muted transition-colors hover:text-cream">Le festival</a></li>
          <li><a href="/programmes" class="text-cream-muted transition-colors hover:text-cream">Programme</a></li>
          <li><a href="/artistes" class="text-cream-muted transition-colors hover:text-cream">Artistes</a></li>
          <li><a href="/scenes" class="text-cream-muted transition-colors hover:text-cream">Scènes</a></li>
          <li><a href="/infos-pratiques" class="text-cream-muted transition-colors hover:text-cream">Infos pratiques</a></li>
          <li><a href="/contact" class="text-cream-muted transition-colors hover:text-cream">Contact</a></li>
        </ul>
      </div>

      <div class="col-span-12 md:col-span-4">
        <p class="mb-4 text-xs font-semibold uppercase tracking-[0.15em] text-gold">
          Contact
        </p>
        <ul class="space-y-2 text-sm text-cream-muted">
          <li>festicloze@gmail.com</li>
          <li>06 67 78 54 54</li>
          <li>Montbéliard, 25200</li>
        </ul>

        <div class="mt-6 flex items-center gap-4">
          <a
            href="#"
            aria-label="Facebook"
            class="text-cream-muted transition-colors hover:text-gold"
          >
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a
            href="#"
            aria-label="Instagram"
            class="text-cream-muted transition-colors hover:text-gold"
          >
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a
            href="#"
            aria-label="Twitter / X"
            class="text-cream-muted transition-colors hover:text-gold"
          >
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
      </div>

    </div>

    <div class="flex flex-col gap-2 border-t border-dark-border py-5 text-xs text-warm-gray sm:flex-row sm:items-center sm:justify-between">
      <p>© {annee} Festicloze — Tous droits réservés</p>
      <div class="flex gap-4">
        <a href="#" class="transition-colors hover:text-cream-muted">Mentions légales</a>
        <a href="/contact" class="transition-colors hover:text-cream-muted">Contact</a>
      </div>
    </div>

  </div>
</footer>