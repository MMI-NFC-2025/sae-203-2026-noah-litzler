---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Connexion">
    <main class="mx-auto max-w-xl px-4 py-10 sm:px-6 lg:px-8">
        <section class="rounded-3xl border border-dark-border bg-dark-card px-6 py-10 md:px-10">
            <p class="mb-3 text-sm uppercase tracking-[0.2em] text-gold">
                Espace utilisateur
            </p>

            <h1 class="font-heading text-4xl font-bold text-cream">
                Connexion
            </h1>

            <p class="mt-4 text-cream-muted">
                Connectez-vous avec votre adresse email et votre mot de passe.
            </p>
        </section>

        <section class="mt-8 rounded-2xl border border-dark-border bg-dark-card p-6">
            <form id="loginForm" class="space-y-5">
                <div>
                    <label for="email" class="mb-2 block text-sm font-medium text-gold">
                        Email
                    </label>
                    <input
                        id="email"
                        type="email"
                        required
                        class="w-full rounded-xl border border-dark-border bg-dark px-4 py-3 text-cream placeholder:text-cream-muted/50 focus:border-gold focus:outline-none"
                        placeholder="exemple@mail.com"
                    />
                </div>

                <div>
                    <label for="password" class="mb-2 block text-sm font-medium text-gold">
                        Mot de passe
                    </label>
                    <input
                        id="password"
                        type="password"
                        required
                        class="w-full rounded-xl border border-dark-border bg-dark px-4 py-3 text-cream placeholder:text-cream-muted/50 focus:border-gold focus:outline-none"
                        placeholder="Votre mot de passe"
                    />
                </div>

                <button
                    type="submit"
                    class="rounded-full bg-gold px-6 py-3 text-sm font-semibold text-dark transition hover:bg-gold-light"
                >
                    Se connecter
                </button>
            </form>

            <p id="message" class="mt-4 text-sm text-cream-muted"></p>

            <div class="mt-6">
                <button
                    id="logoutBtn"
                    class="rounded-full border border-dark-border px-4 py-2 text-sm text-cream-muted transition hover:border-gold hover:text-gold"
                >
                    Se déconnecter
                </button>
            </div>
        </section>
    </main>
<script>
    import { Userauth, isUserValid, currentUser, logoutUser } from '../js/backend.mjs';

    const form = document.getElementById('loginForm') as HTMLFormElement | null;
    const message = document.getElementById('message');
    const logoutBtn = document.getElementById('logoutBtn');

    function afficherEtatConnexion() {
        if (isUserValid()) {
            const user = currentUser();
            if (message) {
                message.textContent = `Connecté : ${user?.email}`;
                message.className = 'mt-4 text-sm text-green-600';
            }
        } else {
            if (message) {
                message.textContent = 'Aucun utilisateur connecté';
                message.className = 'mt-4 text-sm text-cream-muted';
            }
        }
    }

    afficherEtatConnexion();

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();

        const email = (document.getElementById('email') as HTMLInputElement).value;
        const password = (document.getElementById('password') as HTMLInputElement).value;

        try {
            await Userauth(email, password);
            afficherEtatConnexion();
        } catch (error) {
            console.error(error);
            if (message) {
                message.textContent = 'Email ou mot de passe incorrect';
                message.className = 'mt-4 text-sm text-red-600';
            }
        }
    });

    logoutBtn?.addEventListener('click', () => {
        logoutUser();
        afficherEtatConnexion();
    });
</script>
</Layout>