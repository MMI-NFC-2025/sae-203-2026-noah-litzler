---
import Layout from '../../layouts/Layout.astro';
import { allScenesSorted, getImageUrl } from '../../js/backend.mjs';

const scenes = await allScenesSorted();
---

<Layout title="Scènes">
  <main class="container py-10">

    <section class="mb-10 rounded-3xl bg-dark-card px-6 py-10 md:px-10" style="border: 1px solid #2a2a2a;">
      <p class="mb-3 text-sm uppercase tracking-[0.2em] text-cream-muted">
        Festicloze 2026
      </p>
      <h1 class="text-4xl font-bold text-cream md:text-5xl">Les scènes</h1>
      <p class="mt-4 max-w-2xl text-cream-muted">
        Découvrez les lieux emblématiques de Montbéliard qui accueillent le festival.
      </p>
    </section>

    <section class="row gap-8">
      {scenes.map((scene) => (
        <article class="col-span-12 md:col-span-6 lg:col-span-4 group overflow-hidden rounded-2xl border border-dark-border bg-dark-card transition-colors duration-200 hover:border-gold/40">
          <a href={`/scenes/${scene.id}`}>
            {getImageUrl(scene, 'photo') && (
              <div class="overflow-hidden">
                <img
                  src={getImageUrl(scene, 'photo')}
                  alt={scene.nom}
                  class="h-56 w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
              </div>
            )}
            <div class="p-5">
              <h2 class="text-2xl font-semibold text-cream group-hover:text-gold transition-colors duration-200">
                {scene.nom}
              </h2>
            </div>
          </a>
          <div class="px-5 pb-5">
            <p class="text-sm text-cream-muted">
              <span class="text-gold">📍</span> {scene.localisation}
            </p>
            {scene.capacite && (
              <p class="mt-1 text-sm text-cream-muted">
                Capacité : {scene.capacite} personnes
              </p>
            )}
            {scene.description && (
              <p class="mt-3 text-sm leading-relaxed text-cream-muted line-clamp-3">
                {scene.description}
              </p>
            )}
            <a
              href={`/scenes/${scene.id}`}
              class="mt-4 inline-block rounded-full border border-gold/40 px-4 py-1.5 text-sm text-gold transition-all duration-200 hover:bg-gold hover:text-dark"
            >
              Voir la scène
            </a>
          </div>
        </article>
      ))}
    </section>

  </main>
</Layout>