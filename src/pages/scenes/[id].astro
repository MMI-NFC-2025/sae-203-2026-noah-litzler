---
import Layout from '../../layouts/Layout.astro';
import {
    allScenesSorted,
    oneSceneID,
    allRepresentationsByScene,
    getImageUrl
} from '../../js/backend.mjs';

export async function getStaticPaths() {
    const scenes = await allScenesSorted();

    return scenes.map((scene) => ({
        params: { id: scene.id }
    }));
}

const { id } = Astro.params;

const scene = await oneSceneID(id);
const representations = await allRepresentationsByScene(id);

const photoScene = getImageUrl(scene, 'photo');
---

<Layout title={scene.nom}>
  <main class="container py-10">

    <a
      href="/scenes"
      class="mb-8 inline-flex items-center gap-2 text-sm text-cream-muted transition-colors hover:text-gold"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
      Retour aux scènes
    </a>

    {photoScene && (
      <div class="mb-10 overflow-hidden rounded-3xl border border-dark-border">
        <img
          src={photoScene}
          alt={scene.nom}
          class="h-72 w-full object-cover md:h-96"
        />
      </div>
    )}

    <section class="grid grid-cols-1 gap-8 md:grid-cols-3 mb-12">
      <div class="md:col-span-2">
        <h1 class="text-4xl font-bold text-cream md:text-5xl">
          {scene.nom}
        </h1>
        {scene.description && (
          <p class="mt-5 leading-relaxed text-cream-muted">
            {scene.description}
          </p>
        )}
      </div>

      <div class="rounded-2xl border border-dark-border bg-dark-card p-6">
        <p class="mb-4 text-xs font-semibold uppercase tracking-[0.15em] text-gold">
          Informations
        </p>
        <ul class="space-y-3 text-sm">
          {scene.localisation && (
            <li class="flex gap-2 text-cream-muted">
              <span class="text-gold shrink-0">📍</span>
              <span>{scene.localisation}</span>
            </li>
          )}
          {scene.capacite && (
            <li class="flex gap-2 text-cream-muted">
              <span class="text-gold shrink-0">👥</span>
              <span>{scene.capacite} personnes</span>
            </li>
          )}
        </ul>
      </div>
    </section>

    {representations.length > 0 && (
      <section>
        <p class="mb-5 text-xs font-semibold uppercase tracking-[0.15em] text-gold">
          Artistes programmés sur cette scène
        </p>
        <div class="space-y-3">
          {representations.map((rep) => (
            <article class="flex items-center justify-between rounded-xl border border-dark-border bg-dark-card px-5 py-4">
              <div>
                <p class="font-heading text-lg font-semibold text-cream">
                  {rep.expand?.artiste ? (
                    <a href={`/artistes/${rep.expand.artiste.id}`} class="hover:text-gold transition-colors">
                      {rep.expand.artiste.nom}
                    </a>
                  ) : 'Artiste inconnu'}
                </p>
                {rep.description && (
                  <p class="mt-1 text-sm text-cream-muted">{rep.description}</p>
                )}
              </div>
              <time class="shrink-0 rounded-full bg-dark-border px-3 py-1.5 text-sm font-medium text-cream-muted ml-4">
                {new Date(rep.date_heure).toLocaleDateString('fr-FR', {
                  day: 'numeric',
                  month: 'short'
                })}
                {' '}
                {new Date(rep.date_heure).toLocaleTimeString('fr-FR', {
                  hour: '2-digit',
                  minute: '2-digit'
                })}
              </time>
            </article>
          ))}
        </div>
      </section>
    )}

  </main>
</Layout>