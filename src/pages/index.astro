---
import Layout from '../layouts/Layout.astro';
import {
    allArtistesAlpha,
    allScenesSorted,
    allRepresentationsSorted,
    getImageUrl
} from '../js/backend.mjs';

const artistes = (await allArtistesAlpha()).slice(0, 3);
const scenes = (await allScenesSorted()).slice(0, 2);
const representations = (await allRepresentationsSorted()).slice(0, 4);

const joursUniques = [
    ...new Set(
        representations.map((rep) =>
            new Date(rep.date_heure).toLocaleDateString('fr-FR', {
                weekday: 'long',
                day: 'numeric',
                month: 'long',
                year: 'numeric'
            })
        )
    )
];

const partenaires = [
    'Ville de Montbéliard',
    'Pays de Montbéliard Agglomération',
    'Région Bourgogne-Franche-Comté',
    'Université Marie et Louis Pasteur'
];
---

<Layout title="Festicloze 2026">
    <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
        <section class="rounded-3xl bg-zinc-900 px-6 py-12 text-white md:px-10 lg:px-12">
            <p class="mb-3 text-sm uppercase tracking-[0.2em] text-zinc-300">
                Festival Festicloze 2026
            </p>

            <h1 class="max-w-3xl text-4xl font-bold md:text-5xl lg:text-6xl">
                Un festival musical entre patrimoine, lumière et émotions
            </h1>

            <p class="mt-5 max-w-2xl text-zinc-200">
                Découvrez une programmation unique mêlant artistes invités, scènes emblématiques
                et concerts répartis sur plusieurs jours au cœur de Montbéliard.
            </p>

            <div class="mt-8 flex flex-wrap gap-4">
                <a
                    href="#"
                    class="rounded-full bg-white px-5 py-3 text-sm font-semibold text-black transition hover:bg-zinc-200"
                >
                    Accéder à la billetterie
                </a>

                <a
                    href="/programmes"
                    class="rounded-full border border-white px-5 py-3 text-sm font-semibold text-white transition hover:bg-white hover:text-black"
                >
                    Voir le programme
                </a>
            </div>
        </section>

        <section class="mt-12">
            <h2 class="mb-6 text-3xl font-bold text-zinc-900">Dates clés du festival</h2>

            <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4">
                {joursUniques.map((jour) => (
                    <article class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
                        <p class="capitalize text-lg font-semibold text-zinc-900">{jour}</p>
                    </article>
                ))}
            </div>
        </section>

        <section class="mt-14">
            <div class="mb-6 flex items-center justify-between">
                <h2 class="text-3xl font-bold text-zinc-900">Aperçu du programme</h2>
                <a href="/programmes" class="text-sm font-medium underline">
                    Tout voir
                </a>
            </div>

            <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
                {representations.map((rep) => (
                    <article class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
                        <p class="text-sm text-zinc-500">
                            {new Date(rep.date_heure).toLocaleDateString('fr-FR')} à {new Date(rep.date_heure).toLocaleTimeString('fr-FR', {
                                hour: '2-digit',
                                minute: '2-digit'
                            })}
                        </p>

                        <h3 class="mt-2 text-2xl font-semibold text-zinc-900">
                            {rep.expand?.artiste?.nom}
                        </h3>

                        <p class="mt-2 text-zinc-700">
                            <strong>Scène :</strong> {rep.expand?.scene?.nom}
                        </p>

                        {rep.description && (
                            <p class="mt-3 text-zinc-700">{rep.description}</p>
                        )}
                    </article>
                ))}
            </div>
        </section>

        <section class="mt-14">
            <div class="mb-6 flex items-center justify-between">
                <h2 class="text-3xl font-bold text-zinc-900">Artistes invités</h2>
                <a href="/artistes" class="text-sm font-medium underline">
                    Tous les artistes
                </a>
            </div>

            <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
                {artistes.map((artiste) => (
                    <article class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm">
                        <a href={`/artistes/${artiste.id}`}>
                            {getImageUrl(artiste, 'photo_principale') && (
                                <img
                                    src={getImageUrl(artiste, 'photo_principale')}
                                    alt={artiste.nom}
                                    class="mb-4 h-72 w-full rounded-xl object-cover"
                                />
                            )}

                            <h3 class="text-2xl font-semibold text-zinc-900">
                                {artiste.nom}
                            </h3>
                        </a>

                        <p class="mt-2 text-sm text-zinc-600">
                            {artiste.genre_musical}
                        </p>

                        <p class="mt-3 line-clamp-4 text-zinc-700">
                            {artiste.description}
                        </p>
                    </article>
                ))}
            </div>
        </section>

        <section class="mt-14">
            <div class="mb-6 flex items-center justify-between">
                <h2 class="text-3xl font-bold text-zinc-900">Les scènes</h2>
                <a href="/scenes" class="text-sm font-medium underline">
                    Toutes les scènes
                </a>
            </div>

            <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                {scenes.map((scene) => (
                    <article class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm">
                        <a href={`/scenes/${scene.id}`}>
                            {getImageUrl(scene, 'photo') && (
                                <img
                                    src={getImageUrl(scene, 'photo')}
                                    alt={scene.nom}
                                    class="mb-4 h-72 w-full rounded-xl object-cover"
                                />
                            )}

                            <h3 class="text-2xl font-semibold text-zinc-900">
                                {scene.nom}
                            </h3>
                        </a>

                        <p class="mt-2 text-sm text-zinc-600">
                            {scene.localisation}
                        </p>

                        <p class="mt-3 text-zinc-700">
                            {scene.description}
                        </p>
                    </article>
                ))}
            </div>
        </section>

        <section class="mt-14">
            <h2 class="mb-6 text-3xl font-bold text-zinc-900">Partenaires</h2>

            <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4">
                {partenaires.map((partenaire) => (
                    <article class="rounded-2xl border border-zinc-200 bg-white p-5 text-center shadow-sm">
                        <p class="font-semibold text-zinc-900">{partenaire}</p>
                    </article>
                ))}
            </div>
        </section>
    </main>
</Layout>