---
import Layout from '../../../layouts/Layout.astro';
import ProgrammeItem from '../../../components/ProgrammeItem.astro';
import {
    allScenesSorted,
    oneSceneID,
    allRepresentationsByScene
} from '../../../js/backend.mjs';

export async function getStaticPaths() {
    const scenes = await allScenesSorted();

    return scenes.map((scene) => ({
        params: { id: scene.id }
    }));
}

const { id } = Astro.params;

const scene = await oneSceneID(id);
const representations = await allRepresentationsByScene(id);
---

<Layout title={`Programme - ${scene.nom}`}>
    <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
        <a href="/programmes" class="mb-6 inline-block text-sm underline">
            ← Retour au programme
        </a>

        <section class="mb-10 rounded-3xl bg-zinc-900 px-6 py-10 text-white md:px-10">
            <p class="mb-3 text-sm uppercase tracking-[0.2em] text-zinc-300">
                Programme par scène
            </p>

            <h1 class="text-4xl font-bold md:text-5xl">
                {scene.nom}
            </h1>

            <p class="mt-4 max-w-2xl text-zinc-200">
                Retrouvez tous les artistes programmés sur cette scène, triés par date.
            </p>

            <p class="mt-4 text-zinc-300">
                <strong>Localisation :</strong> {scene.localisation}
            </p>
        </section>

        {representations.length > 0 ? (
            <section class="space-y-4">
                {representations.map((rep) => (
                    <ProgrammeItem representation={rep} />
                ))}
            </section>
        ) : (
            <p>Aucune représentation sur cette scène.</p>
        )}
    </main>
</Layout>