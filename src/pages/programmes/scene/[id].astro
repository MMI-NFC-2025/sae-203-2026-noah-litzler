---
import Layout from '../../../layouts/Layout.astro';
import ProgrammeItem from '../../../components/ProgrammeItem.astro';
import {
    allScenesSorted,
    oneSceneID,
    allRepresentationsByScene
} from '../../../js/backend.mjs';

export async function getStaticPaths() {
    const scenes = await allScenesSorted();

    return scenes.map((scene) => ({
        params: { id: scene.id }
    }));
}

const { id } = Astro.params;

const scene = await oneSceneID(id);
const representations = await allRepresentationsByScene(id);
---

<Layout title={`Programme - ${scene.nom}`}>
    <main class="container py-10">
        <a href="/programmes" class="mb-6 inline-block text-sm font-medium text-gold hover:underline">
            ← Retour au programme
        </a>

        <section class="mb-10 rounded-3xl border border-dark-border bg-dark-card px-6 py-10 md:px-10">
            <p class="mb-3 text-sm uppercase tracking-[0.2em] text-gold">
                Programme par scène
            </p>

            <h1 class="font-heading text-4xl font-bold text-cream md:text-5xl">
                {scene.nom}
            </h1>

            <p class="mt-4 max-w-2xl text-cream-muted">
                Retrouvez tous les artistes programmés sur cette scène, triés par date.
            </p>

            <p class="mt-4 text-cream-muted">
                <strong class="text-gold">Localisation :</strong> {scene.localisation}
            </p>
        </section>

        {representations.length > 0 ? (
            <section class="space-y-4">
                {representations.map((rep) => (
                    <ProgrammeItem representation={rep} />
                ))}
            </section>
        ) : (
            <p class="text-cream-muted">Aucune représentation sur cette scène.</p>
        )}
    </main>
</Layout>