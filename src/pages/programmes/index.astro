---
import Layout from '../../layouts/Layout.astro';
import ProgrammeItem from '../../components/ProgrammeItem.astro';
import { allRepresentationsSorted } from '../../js/backend.mjs';

const representations = await allRepresentationsSorted();

const programmeParJour = new Map();

for (const rep of representations) {
    const date = new Date(rep.date_heure);

    const jourLabel = date.toLocaleDateString('fr-FR', {
        weekday: 'long',
        day: 'numeric',
        month: 'long',
        year: 'numeric'
    });

    const jourUrl = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`;

    if (!programmeParJour.has(jourUrl)) {
        programmeParJour.set(jourUrl, {
            label: jourLabel,
            reps: []
        });
    }

    programmeParJour.get(jourUrl).reps.push(rep);
}

const jours = Array.from(programmeParJour.entries());

const genres = [
    ...new Set(
        representations
            .map((rep) => rep.expand?.artiste?.genre_musical)
            .filter(Boolean)
    )
].sort();

const scenes = [
    ...new Set(
        representations
            .map((rep) => rep.expand?.scene?.nom)
            .filter(Boolean)
    )
].sort();

const heures = [
    ...new Set(
        representations.map((rep) =>
            new Date(rep.date_heure).toLocaleTimeString('fr-FR', {
                hour: '2-digit',
                minute: '2-digit'
            })
        )
    )
].sort();
---

<Layout title="Programme">
    <main class="container py-10">
        <section class="mb-10 overflow-hidden rounded-3xl border border-dark-border bg-dark-card">
            <div class="px-8 py-12 md:px-14">
                <p class="mb-3 text-sm uppercase tracking-[0.2em] text-gold">
                    Festicloze 2026
                </p>

                <h1 class="font-heading text-4xl font-bold text-cream md:text-5xl">
                    Le programme du festival
                </h1>

                <p class="mt-4 max-w-2xl text-cream-muted">
                    Retrouvez tous les artistes programmés, classés par jour, avec des filtres par genre, horaire et scène.
                </p>

                <div class="mt-6">
                    <a
                        href="/programme.pdf"
                        class="inline-flex rounded-full bg-gold px-5 py-3 text-sm font-semibold text-dark transition-colors hover:bg-gold-light"
                    >
                        Télécharger le programme PDF
                    </a>
                </div>
            </div>
        </section>

        <section class="mb-10 rounded-2xl border border-dark-border bg-dark-card p-5">
            <h2 class="mb-4 font-heading text-2xl font-semibold text-cream">
                Filtrer le programme
            </h2>

            <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
                <div>
                    <label for="genreFilter" class="mb-2 block text-sm font-medium text-gold">
                        Genre musical
                    </label>
                    <select
                        id="genreFilter"
                        class="w-full rounded-xl border border-dark-border bg-dark px-4 py-3 text-cream"
                    >
                        <option value="">Tous les genres</option>
                        {genres.map((genre) => (
                            <option value={genre}>{genre}</option>
                        ))}
                    </select>
                </div>

                <div>
                    <label for="heureFilter" class="mb-2 block text-sm font-medium text-gold">
                        Horaire
                    </label>
                    <select
                        id="heureFilter"
                        class="w-full rounded-xl border border-dark-border bg-dark px-4 py-3 text-cream"
                    >
                        <option value="">Tous les horaires</option>
                        {heures.map((heure) => (
                            <option value={heure}>{heure}</option>
                        ))}
                    </select>
                </div>

                <div>
                    <label for="sceneFilter" class="mb-2 block text-sm font-medium text-gold">
                        Scène
                    </label>
                    <select
                        id="sceneFilter"
                        class="w-full rounded-xl border border-dark-border bg-dark px-4 py-3 text-cream"
                    >
                        <option value="">Toutes les scènes</option>
                        {scenes.map((scene) => (
                            <option value={scene}>{scene}</option>
                        ))}
                    </select>
                </div>
            </div>

            <button
                id="resetFilters"
                class="mt-4 rounded-full border border-dark-border px-4 py-2 text-sm text-cream-muted transition-colors hover:border-gold hover:text-gold"
            >
                Réinitialiser les filtres
            </button>
        </section>

        <section class="space-y-10">
            {jours.map(([jourUrl, data]) => (
                <section data-jour-section>
                    <h2 class="mb-5 font-heading text-2xl font-bold capitalize text-cream">
                        <a href={`/programmes/jour/${jourUrl}`} class="transition-colors hover:text-gold">
                            {data.label}
                        </a>
                    </h2>

                    <div class="space-y-4">
                        {data.reps.map((rep: any) => (
                            <ProgrammeItem representation={rep} />
                        ))}
                    </div>
                </section>
            ))}
        </section>
    </main>

    <script>
        const genreFilter  = document.getElementById('genreFilter')  as HTMLSelectElement | null;
        const heureFilter  = document.getElementById('heureFilter')  as HTMLSelectElement | null;
        const sceneFilter  = document.getElementById('sceneFilter')  as HTMLSelectElement | null;
        const resetFilters = document.getElementById('resetFilters') as HTMLButtonElement | null;

        const items    = document.querySelectorAll<HTMLElement>('[data-programme-item]');
        const sections = document.querySelectorAll<HTMLElement>('[data-jour-section]');

        if (genreFilter && heureFilter && sceneFilter && resetFilters) {
            function appliquerFiltres() {
                const genreValue = genreFilter!.value;
                const heureValue = heureFilter!.value;
                const sceneValue = sceneFilter!.value;

                items.forEach((item) => {
                    const matchGenre = !genreValue || item.dataset.genre === genreValue;
                    const matchHeure = !heureValue || item.dataset.heure === heureValue;
                    const matchScene = !sceneValue || item.dataset.scene === sceneValue;

                    item.style.display = (matchGenre && matchHeure && matchScene) ? '' : 'none';
                });

                sections.forEach((section) => {
                    const hasVisible = [...section.querySelectorAll<HTMLElement>('[data-programme-item]')]
                        .some((item) => item.style.display !== 'none');
                    section.style.display = hasVisible ? '' : 'none';
                });
            }

            genreFilter.addEventListener('change', appliquerFiltres);
            heureFilter.addEventListener('change', appliquerFiltres);
            sceneFilter.addEventListener('change', appliquerFiltres);

            resetFilters.addEventListener('click', () => {
                genreFilter.value  = '';
                heureFilter.value  = '';
                sceneFilter.value  = '';
                appliquerFiltres();
            });
        }
    </script>
</Layout>