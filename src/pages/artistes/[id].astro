---
import Layout from '../../layouts/Layout.astro';
import {
    allArtistesAlpha,
    oneArtisteID,
    allRepresentationsByArtiste,
    getImageUrl,
    getImageUrls
} from '../../js/backend.mjs';

export async function getStaticPaths() {
    const artistes = await allArtistesAlpha();

    return artistes.map((artiste) => ({
        params: { id: artiste.id }
    }));
}

const { id } = Astro.params;

const artiste = await oneArtisteID(id);
const representations = await allRepresentationsByArtiste(id);

const photoPrincipale = getImageUrl(artiste, 'photo_principale');
const galerie = getImageUrls(artiste, 'galerie_photos');
---

<Layout title={artiste.nom}>
    <main class="container">
        <a href="/artistes">← Retour aux artistes</a>

        <section class="fiche-artiste">
            <div class="image-artiste">
                {photoPrincipale && (
                    <img src={photoPrincipale} alt={artiste.nom} />
                )}
            </div>

            <div class="infos-artiste">
                <h1>{artiste.nom}</h1>
                <p><strong>Genre :</strong> {artiste.genre_musical}</p>
                <p>{artiste.description}</p>

                <h2>Dates de représentation</h2>
                <ul>
                    {representations.map((rep) => (
                        <li>
                            {new Date(rep.date_heure).toLocaleDateString('fr-FR')} à {new Date(rep.date_heure).toLocaleTimeString('fr-FR', {
                                hour: '2-digit',
                                minute: '2-digit'
                            })}
                            {rep.expand?.scene ? ` - ${rep.expand.scene.nom}` : ''}
                        </li>
                    ))}
                </ul>
            </div>
        </section>

        {galerie.length > 0 && (
            <section class="galerie">
                <h2>Galerie photo</h2>
                <div class="grille-galerie">
                    {galerie.map((img, index) => (
                        <img src={img} alt={`${artiste.nom} ${index + 1}`} />
                    ))}
                </div>
            </section>
        )}
    </main>
</Layout>

<style>
.container {
    width: 90%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 0;
}

.fiche-artiste {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-top: 2rem;
    margin-bottom: 3rem;
}

.image-artiste img {
    width: 100%;
    border-radius: 12px;
    object-fit: cover;
}

.infos-artiste h1 {
    margin-top: 0;
}

.galerie h2 {
    margin-bottom: 1rem;
}

.grille-galerie {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
}

.grille-galerie img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    border-radius: 10px;
}

@media (max-width: 800px) {
    .fiche-artiste {
        grid-template-columns: 1fr;
    }
}
</style>