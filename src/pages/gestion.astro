---
import Layout from '../layouts/Layout.astro';
import { allScenesSorted } from '../js/backend.mjs';

const scenes = await allScenesSorted();
---

<Layout title="Gestion">
    <main class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
        <section class="mb-10 rounded-3xl bg-zinc-900 px-6 py-10 text-white md:px-10">
            <p class="mb-3 text-sm uppercase tracking-[0.2em] text-zinc-300">
                Administration simple
            </p>

            <h1 class="text-4xl font-bold md:text-5xl">
                Gestion des données
            </h1>

            <p class="mt-4 max-w-2xl text-zinc-200">
                Cette page permet d’ajouter un artiste et de modifier une scène directement depuis le front.
            </p>
        </section>

        <section class="grid grid-cols-1 gap-8 lg:grid-cols-2">
            <article class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
                <h2 class="mb-4 text-2xl font-semibold text-zinc-900">
                    Ajouter un artiste
                </h2>

                <form id="artisteForm" class="space-y-4">
                    <div>
                        <label for="nomArtiste" class="mb-2 block text-sm font-medium text-zinc-700">
                            Nom
                        </label>
                        <input
                            id="nomArtiste"
                            type="text"
                            required
                            class="w-full rounded-xl border border-zinc-300 px-4 py-3"
                        />
                    </div>

                    <div>
                        <label for="genreArtiste" class="mb-2 block text-sm font-medium text-zinc-700">
                            Genre musical
                        </label>
                        <input
                            id="genreArtiste"
                            type="text"
                            required
                            class="w-full rounded-xl border border-zinc-300 px-4 py-3"
                        />
                    </div>

                    <div>
                        <label for="descriptionArtiste" class="mb-2 block text-sm font-medium text-zinc-700">
                            Description
                        </label>
                        <textarea
                            id="descriptionArtiste"
                            rows="5"
                            required
                            class="w-full rounded-xl border border-zinc-300 px-4 py-3"
                        ></textarea>
                    </div>

                    <button
                        type="submit"
                        class="rounded-full bg-zinc-900 px-5 py-3 text-sm font-semibold text-white hover:bg-zinc-700"
                    >
                        Ajouter l’artiste
                    </button>
                </form>

                <p id="messageArtiste" class="mt-4 text-sm text-zinc-600"></p>
            </article>

            <article class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
                <h2 class="mb-4 text-2xl font-semibold text-zinc-900">
                    Modifier une scène
                </h2>

                <form id="sceneForm" class="space-y-4">
                    <div>
                        <label for="sceneSelect" class="mb-2 block text-sm font-medium text-zinc-700">
                            Choisir une scène
                        </label>
                        <select
                            id="sceneSelect"
                            class="w-full rounded-xl border border-zinc-300 px-4 py-3"
                            required
                        >
                            <option value="">Sélectionner une scène</option>
                            {scenes.map((scene) => (
                                <option
                                    value={scene.id}
                                    data-nom={scene.nom}
                                    data-description={scene.description}
                                    data-localisation={scene.localisation}
                                    data-capacite={scene.capacite}
                                >
                                    {scene.nom}
                                </option>
                            ))}
                        </select>
                    </div>

                    <div>
                        <label for="nomScene" class="mb-2 block text-sm font-medium text-zinc-700">
                            Nom
                        </label>
                        <input
                            id="nomScene"
                            type="text"
                            required
                            class="w-full rounded-xl border border-zinc-300 px-4 py-3"
                        />
                    </div>

                    <div>
                        <label for="descriptionScene" class="mb-2 block text-sm font-medium text-zinc-700">
                            Description
                        </label>
                        <textarea
                            id="descriptionScene"
                            rows="4"
                            required
                            class="w-full rounded-xl border border-zinc-300 px-4 py-3"
                        ></textarea>
                    </div>

                    <div>
                        <label for="localisationScene" class="mb-2 block text-sm font-medium text-zinc-700">
                            Localisation
                        </label>
                        <input
                            id="localisationScene"
                            type="text"
                            required
                            class="w-full rounded-xl border border-zinc-300 px-4 py-3"
                        />
                    </div>

                    <div>
                        <label for="capaciteScene" class="mb-2 block text-sm font-medium text-zinc-700">
                            Capacité
                        </label>
                        <input
                            id="capaciteScene"
                            type="number"
                            required
                            class="w-full rounded-xl border border-zinc-300 px-4 py-3"
                        />
                    </div>

                    <button
                        type="submit"
                        class="rounded-full bg-zinc-900 px-5 py-3 text-sm font-semibold text-white hover:bg-zinc-700"
                    >
                        Modifier la scène
                    </button>
                </form>

                <p id="messageScene" class="mt-4 text-sm text-zinc-600"></p>
            </article>
        </section>
    </main>

    <script>
        import { addNewArtiste, updateSceneById } from '../js/backend.mjs';

        const artisteForm = document.getElementById('artisteForm');
        const messageArtiste = document.getElementById('messageArtiste');

        artisteForm.addEventListener('submit', async (e) => {
            e.preventDefault();

            const newArtiste = {
                nom: document.getElementById('nomArtiste').value,
                genre_musical: document.getElementById('genreArtiste').value,
                description: document.getElementById('descriptionArtiste').value
            };

            try {
                await addNewArtiste(newArtiste);
                messageArtiste.textContent = 'Artiste ajouté avec succès.';
                messageArtiste.className = 'mt-4 text-sm text-green-600';
                artisteForm.reset();
            } catch (error) {
                console.error(error);
                messageArtiste.textContent = "Erreur lors de l'ajout de l'artiste.";
                messageArtiste.className = 'mt-4 text-sm text-red-600';
            }
        });

        const sceneSelect = document.getElementById('sceneSelect');
        const sceneForm = document.getElementById('sceneForm');
        const messageScene = document.getElementById('messageScene');

        sceneSelect.addEventListener('change', () => {
            const option = sceneSelect.options[sceneSelect.selectedIndex];
            if (!option.value) return;

            document.getElementById('nomScene').value = option.dataset.nom || '';
            document.getElementById('descriptionScene').value = option.dataset.description || '';
            document.getElementById('localisationScene').value = option.dataset.localisation || '';
            document.getElementById('capaciteScene').value = option.dataset.capacite || '';
        });

        sceneForm.addEventListener('submit', async (e) => {
            e.preventDefault();

            const id = sceneSelect.value;

            const updatedScene = {
                nom: document.getElementById('nomScene').value,
                description: document.getElementById('descriptionScene').value,
                localisation: document.getElementById('localisationScene').value,
                capacite: Number(document.getElementById('capaciteScene').value)
            };

            try {
                await updateSceneById(id, updatedScene);
                messageScene.textContent = 'Scène modifiée avec succès.';
                messageScene.className = 'mt-4 text-sm text-green-600';
            } catch (error) {
                console.error(error);
                messageScene.textContent = 'Erreur lors de la modification de la scène.';
                messageScene.className = 'mt-4 text-sm text-red-600';
            }
        });
    </script>
</Layout>