---
import Layout from '../layouts/Layout.astro';
import { allScenesSorted } from '../js/backend.mjs';

const scenes = await allScenesSorted();
---

<Layout title="Gestion">
    <main class="container max-w-5xl py-10">
        <section class="mb-10 rounded-3xl border border-dark-border bg-dark-card px-6 py-10 md:px-10">
            <p class="mb-3 text-sm uppercase tracking-[0.2em] text-gold">
                Administration simple
            </p>

            <h1 class="font-heading text-4xl font-bold text-cream md:text-5xl">
                Gestion des données
            </h1>

            <p class="mt-4 max-w-2xl text-cream-muted">
                Cette page permet d’ajouter un artiste et de modifier une scène directement depuis le front.
            </p>
        </section>

        <section class="grid grid-cols-1 gap-8 lg:grid-cols-2">
            <article class="rounded-2xl border border-dark-border bg-dark-card p-6">
                <h2 class="mb-4 font-heading text-2xl font-semibold text-cream">
                    Ajouter un artiste
                </h2>

                <form id="artisteForm" class="space-y-4">
                    <div>
                        <label for="nomArtiste" class="mb-2 block text-sm font-medium text-gold">
                            Nom
                        </label>
                        <input
                            id="nomArtiste"
                            type="text"
                            required
                            class="w-full rounded-xl border border-dark-border bg-dark px-4 py-3 text-cream focus:border-gold focus:outline-none"
                        />
                    </div>

                    <div>
                        <label for="genreArtiste" class="mb-2 block text-sm font-medium text-gold">
                            Genre musical
                        </label>
                        <input
                            id="genreArtiste"
                            type="text"
                            required
                            class="w-full rounded-xl border border-dark-border bg-dark px-4 py-3 text-cream focus:border-gold focus:outline-none"
                        />
                    </div>

                    <div>
                        <label for="descriptionArtiste" class="mb-2 block text-sm font-medium text-gold">
                            Description
                        </label>
                        <textarea
                            id="descriptionArtiste"
                            rows="5"
                            required
                            class="w-full rounded-xl border border-dark-border bg-dark px-4 py-3 text-cream focus:border-gold focus:outline-none"
                        ></textarea>
                    </div>

                    <button
                        type="submit"
                        class="rounded-full bg-gold px-6 py-3 text-sm font-semibold text-dark transition hover:bg-gold-light"
                    >
                        Ajouter l’artiste
                    </button>
                </form>

                <p id="messageArtiste" class="mt-4 text-sm text-cream-muted"></p>
            </article>

            <article class="rounded-2xl border border-dark-border bg-dark-card p-6">
                <h2 class="mb-4 font-heading text-2xl font-semibold text-cream">
                    Modifier une scène
                </h2>

                <form id="sceneForm" class="space-y-4">
                    <div>
                        <label for="sceneSelect" class="mb-2 block text-sm font-medium text-gold">
                            Choisir une scène
                        </label>
                        <select
                            id="sceneSelect"
                            class="w-full rounded-xl border border-dark-border bg-dark px-4 py-3 text-cream focus:border-gold focus:outline-none"
                            required
                        >
                            <option value="">Sélectionner une scène</option>
                            {scenes.map((scene) => (
                                <option
                                    value={scene.id}
                                    data-nom={scene.nom}
                                    data-description={scene.description}
                                    data-localisation={scene.localisation}
                                    data-capacite={scene.capacite}
                                >
                                    {scene.nom}
                                </option>
                            ))}
                        </select>
                    </div>

                    <div>
                        <label for="nomScene" class="mb-2 block text-sm font-medium text-gold">
                            Nom
                        </label>
                        <input
                            id="nomScene"
                            type="text"
                            required
                            class="w-full rounded-xl border border-dark-border bg-dark px-4 py-3 text-cream focus:border-gold focus:outline-none"
                        />
                    </div>

                    <div>
                        <label for="descriptionScene" class="mb-2 block text-sm font-medium text-gold">
                            Description
                        </label>
                        <textarea
                            id="descriptionScene"
                            rows="4"
                            required
                            class="w-full rounded-xl border border-dark-border bg-dark px-4 py-3 text-cream focus:border-gold focus:outline-none"
                        ></textarea>
                    </div>

                    <div>
                        <label for="localisationScene" class="mb-2 block text-sm font-medium text-gold">
                            Localisation
                        </label>
                        <input
                            id="localisationScene"
                            type="text"
                            required
                            class="w-full rounded-xl border border-dark-border bg-dark px-4 py-3 text-cream focus:border-gold focus:outline-none"
                        />
                    </div>

                    <div>
                        <label for="capaciteScene" class="mb-2 block text-sm font-medium text-gold">
                            Capacité
                        </label>
                        <input
                            id="capaciteScene"
                            type="number"
                            required
                            class="w-full rounded-xl border border-dark-border bg-dark px-4 py-3 text-cream focus:border-gold focus:outline-none"
                        />
                    </div>

                    <button
                        type="submit"
                        class="rounded-full bg-gold px-6 py-3 text-sm font-semibold text-dark transition hover:bg-gold-light"
                    >
                        Modifier la scène
                    </button>
                </form>

                <p id="messageScene" class="mt-4 text-sm text-cream-muted"></p>
            </article>
        </section>
    </main>

    <script>
        import { addNewArtiste, updateSceneById } from '../js/backend.mjs';

        const artisteForm = document.getElementById('artisteForm') as HTMLFormElement | null;
        const messageArtiste = document.getElementById('messageArtiste');

        artisteForm?.addEventListener('submit', async (e) => {
            e.preventDefault();

            const newArtiste = {
                nom: (document.getElementById('nomArtiste') as HTMLInputElement).value,
                genre_musical: (document.getElementById('genreArtiste') as HTMLInputElement).value,
                description: (document.getElementById('descriptionArtiste') as HTMLTextAreaElement).value
            };

            try {
                await addNewArtiste(newArtiste);
                if (messageArtiste) {
                    messageArtiste.textContent = "Artiste ajouté avec succès.";
                    messageArtiste.className = 'mt-4 text-sm text-green-600';
                }
                artisteForm?.reset();
            } catch (error) {
                console.error(error);
                if (messageArtiste) {
                    messageArtiste.textContent = "Erreur lors de l'ajout de l'artiste.";
                    messageArtiste.className = 'mt-4 text-sm text-red-600';
                }
            }
        });

        const sceneSelect = document.getElementById('sceneSelect') as HTMLSelectElement | null;
        const sceneForm = document.getElementById('sceneForm') as HTMLFormElement | null;
        const messageScene = document.getElementById('messageScene');

        sceneSelect?.addEventListener('change', () => {
            if (!sceneSelect) return;
            const option = sceneSelect.options[sceneSelect.selectedIndex];
            if (!option.value) return;

            (document.getElementById('nomScene') as HTMLInputElement).value = option.dataset.nom || '';
            (document.getElementById('descriptionScene') as HTMLTextAreaElement).value = option.dataset.description || '';
            (document.getElementById('localisationScene') as HTMLInputElement).value = option.dataset.localisation || '';
            (document.getElementById('capaciteScene') as HTMLInputElement).value = option.dataset.capacite || '';
        });

        sceneForm?.addEventListener('submit', async (e) => {
            e.preventDefault();
            if (!sceneSelect) return;

            const id = sceneSelect.value;

            const updatedScene = {
                nom: (document.getElementById('nomScene') as HTMLInputElement).value,
                description: (document.getElementById('descriptionScene') as HTMLTextAreaElement).value,
                localisation: (document.getElementById('localisationScene') as HTMLInputElement).value,
                capacite: Number((document.getElementById('capaciteScene') as HTMLInputElement).value)
            };

            try {
                await updateSceneById(id, updatedScene);
                if (messageScene) {
                    messageScene.textContent = 'Scène modifiée avec succès.';
                    messageScene.className = 'mt-4 text-sm text-green-600';
                }
            } catch (error) {
                console.error(error);
                if (messageScene) {
                    messageScene.textContent = 'Erreur lors de la modification de la scène.';
                    messageScene.className = 'mt-4 text-sm text-red-600';
                }
            }
        });
    </script>
</Layout>