---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
    <main class="container py-10">
        <section class="mb-10 rounded-3xl border border-dark-border bg-dark-card px-6 py-10 md:px-10">
            <p class="mb-3 text-sm uppercase tracking-[0.2em] text-gold">
                Festicloze 2026
            </p>

            <h1 class="font-heading text-4xl font-bold text-cream md:text-5xl">
                Contact
            </h1>

            <p class="mt-4 max-w-2xl text-cream-muted">
                Une question sur le festival ? Contactez-nous via le formulaire ci-dessous.
            </p>
        </section>

        <section class="row gap-8">
            <div class="col-span-12 lg:col-span-6 rounded-2xl border border-dark-border bg-dark-card p-6">
                <h2 class="mb-4 font-heading text-2xl font-semibold text-cream">
                    Formulaire de contact
                </h2>

                <form id="contactForm" class="space-y-5">
                    <div>
                        <label for="nom" class="mb-2 block text-sm font-medium text-gold">
                            Nom
                        </label>
                        <input
                            id="nom"
                            type="text"
                            required
                            class="w-full rounded-xl border border-dark-border bg-dark px-4 py-3 text-cream placeholder:text-cream-muted/50 focus:border-gold focus:outline-none"
                            placeholder="Votre nom"
                        />
                    </div>

                    <div>
                        <label for="email" class="mb-2 block text-sm font-medium text-gold">
                            Email
                        </label>
                        <input
                            id="email"
                            type="email"
                            required
                            class="w-full rounded-xl border border-dark-border bg-dark px-4 py-3 text-cream placeholder:text-cream-muted/50 focus:border-gold focus:outline-none"
                            placeholder="votre@email.com"
                        />
                    </div>

                    <div>
                        <label for="sujet" class="mb-2 block text-sm font-medium text-gold">
                            Sujet
                        </label>
                        <input
                            id="sujet"
                            type="text"
                            required
                            class="w-full rounded-xl border border-dark-border bg-dark px-4 py-3 text-cream placeholder:text-cream-muted/50 focus:border-gold focus:outline-none"
                            placeholder="Sujet du message"
                        />
                    </div>

                    <div>
                        <label for="messageInput" class="mb-2 block text-sm font-medium text-gold">
                            Message
                        </label>
                        <textarea
                            id="messageInput"
                            required
                            rows="6"
                            class="w-full rounded-xl border border-dark-border bg-dark px-4 py-3 text-cream placeholder:text-cream-muted/50 focus:border-gold focus:outline-none"
                            placeholder="Votre message"
                        ></textarea>
                    </div>

                    <button
                        type="submit"
                        class="rounded-full bg-gold px-6 py-3 text-sm font-semibold text-dark transition hover:bg-gold-light"
                    >
                        Envoyer
                    </button>
                </form>

                <p id="contactMessage" class="mt-4 text-sm text-cream-muted"></p>
            </div>

            <div class="col-span-12 lg:col-span-6 space-y-8">
                <section class="rounded-2xl border border-dark-border bg-dark-card p-6">
                    <h2 class="mb-4 font-heading text-2xl font-semibold text-cream">
                        Coordonnées
                    </h2>

                    <ul class="space-y-3 text-cream-muted">
                        <li>
                            <strong class="text-gold">Email :</strong> contact@festicloze.fr
                        </li>
                        <li>
                            <strong class="text-gold">Téléphone :</strong> 03 89 74 20 83
                        </li>
                        <li>
                            <strong class="text-gold">Adresse :</strong> Montbéliard, France
                        </li>
                    </ul>
                </section>

                <section class="rounded-2xl border border-dark-border bg-dark-card p-6">
                    <h2 class="mb-4 font-heading text-2xl font-semibold text-cream">
                        Réseaux sociaux
                    </h2>

                    <ul class="space-y-3 text-cream-muted">
                        <li>
                            <a href="#" class="text-gold hover:underline">Instagram</a>
                        </li>
                        <li>
                            <a href="#" class="text-gold hover:underline">Facebook</a>
                        </li>
                        <li>
                            <a href="#" class="text-gold hover:underline">TikTok</a>
                        </li>
                    </ul>
                </section>
            </div>
        </section>
    </main>

    <script>
        import { addNewMessageContact } from '../js/backend.mjs';

        const form = document.getElementById('contactForm') as HTMLFormElement | null;
        const contactMessage = document.getElementById('contactMessage');

        form?.addEventListener('submit', async (e) => {
            e.preventDefault();

            const newMessage = {
                nom: (document.getElementById('nom') as HTMLInputElement).value,
                email: (document.getElementById('email') as HTMLInputElement).value,
                sujet: (document.getElementById('sujet') as HTMLInputElement).value,
                message: (document.getElementById('messageInput') as HTMLTextAreaElement).value
            };

            try {
                await addNewMessageContact(newMessage);
                if (contactMessage) {
                    contactMessage.textContent = 'Message envoyé avec succès.';
                    contactMessage.className = 'mt-4 text-sm text-green-600';
                }
                form?.reset();
            } catch (error) {
                console.error(error);
                if (contactMessage) {
                    contactMessage.textContent = "Erreur lors de l'envoi du message.";
                    contactMessage.className = 'mt-4 text-sm text-red-600';
                }
            }
        });
    </script>
</Layout>