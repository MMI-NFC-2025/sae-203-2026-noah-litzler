---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
    <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
        <section class="mb-10 rounded-3xl bg-zinc-900 px-6 py-10 text-white md:px-10">
            <p class="mb-3 text-sm uppercase tracking-[0.2em] text-zinc-300">
                Festicloze 2026
            </p>

            <h1 class="text-4xl font-bold md:text-5xl">
                Contact
            </h1>

            <p class="mt-4 max-w-2xl text-zinc-200">
                Une question sur le festival ? Contactez-nous via le formulaire ci-dessous.
            </p>
        </section>

        <section class="grid grid-cols-1 gap-8 lg:grid-cols-2">
            <div class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
                <h2 class="mb-4 text-2xl font-semibold text-zinc-900">
                    Formulaire de contact
                </h2>

                <form id="contactForm" class="space-y-5">
                    <div>
                        <label for="nom" class="mb-2 block text-sm font-medium text-zinc-700">
                            Nom
                        </label>
                        <input
                            id="nom"
                            type="text"
                            required
                            class="w-full rounded-xl border border-zinc-300 px-4 py-3"
                            placeholder="Votre nom"
                        />
                    </div>

                    <div>
                        <label for="email" class="mb-2 block text-sm font-medium text-zinc-700">
                            Email
                        </label>
                        <input
                            id="email"
                            type="email"
                            required
                            class="w-full rounded-xl border border-zinc-300 px-4 py-3"
                            placeholder="votre@email.com"
                        />
                    </div>

                    <div>
                        <label for="sujet" class="mb-2 block text-sm font-medium text-zinc-700">
                            Sujet
                        </label>
                        <input
                            id="sujet"
                            type="text"
                            required
                            class="w-full rounded-xl border border-zinc-300 px-4 py-3"
                            placeholder="Sujet du message"
                        />
                    </div>

                    <div>
                        <label for="messageInput" class="mb-2 block text-sm font-medium text-zinc-700">
                            Message
                        </label>
                        <textarea
                            id="messageInput"
                            required
                            rows="6"
                            class="w-full rounded-xl border border-zinc-300 px-4 py-3"
                            placeholder="Votre message"
                        ></textarea>
                    </div>

                    <button
                        type="submit"
                        class="rounded-full bg-zinc-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-zinc-700"
                    >
                        Envoyer
                    </button>
                </form>

                <p id="contactMessage" class="mt-4 text-sm text-zinc-600"></p>
            </div>

            <div class="space-y-8">
                <section class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
                    <h2 class="mb-4 text-2xl font-semibold text-zinc-900">
                        Coordonnées
                    </h2>

                    <ul class="space-y-3 text-zinc-700">
                        <li>
                            <strong>Email :</strong> contact@festicloze.fr
                        </li>
                        <li>
                            <strong>Téléphone :</strong> 03 81 00 00 00
                        </li>
                        <li>
                            <strong>Adresse :</strong> Montbéliard, France
                        </li>
                    </ul>
                </section>

                <section class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
                    <h2 class="mb-4 text-2xl font-semibold text-zinc-900">
                        Réseaux sociaux
                    </h2>

                    <ul class="space-y-3 text-zinc-700">
                        <li>
                            <a href="#" class="underline">Instagram</a>
                        </li>
                        <li>
                            <a href="#" class="underline">Facebook</a>
                        </li>
                        <li>
                            <a href="#" class="underline">TikTok</a>
                        </li>
                    </ul>
                </section>
            </div>
        </section>
    </main>

    <script>
        import { addNewMessageContact } from '../js/backend.mjs';

        const form = document.getElementById('contactForm');
        const contactMessage = document.getElementById('contactMessage');

        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const newMessage = {
                nom: document.getElementById('nom').value,
                email: document.getElementById('email').value,
                sujet: document.getElementById('sujet').value,
                message: document.getElementById('messageInput').value
            };

            try {
                await addNewMessageContact(newMessage);
                contactMessage.textContent = 'Message envoyé avec succès.';
                contactMessage.className = 'mt-4 text-sm text-green-600';
                form.reset();
            } catch (error) {
                console.error(error);
                contactMessage.textContent = 'Erreur lors de l’envoi du message.';
                contactMessage.className = 'mt-4 text-sm text-red-600';
            }
        });
    </script>
</Layout>