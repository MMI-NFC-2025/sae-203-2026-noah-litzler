---
import Layout from '../layouts/Layout.astro';

const organisateurs = [
    {
        nom: 'Direction du festival',
        description: "Pilotage général de l'événement, coordination des équipes et suivi de la programmation.",
        photo: '/equipe1.avif'
    },
    {
        nom: 'Pôle production',
        description: "Organisation des représentations, gestion logistique des lieux et accueil des artistes.",
        photo: '/equipe2.avif'
    },
    {
        nom: 'Pôle communication',
        description: "Diffusion des informations, valorisation du festival et relation avec le public.",
        photo: '/equipe3.avif'
    },
    {
        nom: 'Pôle partenariats',
        description: "Développement des liens avec les acteurs culturels et institutionnels du territoire.",
        photo: '/equipe4.avif'
    }
];

const equipeTechnique = [
    {
        nom: 'Régie son',
        description: "Mise en place et suivi technique des concerts sur les différentes scènes.",
        photo: '/equipe5.avif'
    },
    {
        nom: 'Régie lumière',
        description: "Création des ambiances visuelles et accompagnement des représentations.",
        photo: '/equipe6.png'
    },
    {
        nom: 'Installation et accueil',
        description: "Préparation des espaces, accompagnement du public et bon déroulement des soirées.",
        photo: '/equipe7.png'
    }
];

const valeurs = [
    {
        titre: 'Le partage',
        texte: "Festicloze réunit plusieurs générations autour d’un moment culturel fort. Le festival encourage la rencontre, la transmission et le plaisir collectif de vivre la musique ensemble."
    },
    {
        titre: 'La tradition',
        texte: "Le festival valorise le patrimoine musical baroque et les lieux emblématiques de Montbéliard afin d’ancrer l’événement dans l’histoire et l’identité locale."
    },
    {
        titre: 'L’émerveillement',
        texte: "La musique, la lumière, les décors et l’atmosphère de Noël participent à une expérience immersive pensée pour émerveiller le public."
    }
];
---

<Layout title="Historique - Festicloze">
    <main class="container py-10">
        <section class="mb-10 overflow-hidden rounded-3xl border border-dark-border bg-dark-card">
            <div class="flex flex-col lg:flex-row">
                <div class="flex flex-col justify-center px-8 py-12 lg:w-1/2 lg:px-14">
                    <p class="mb-3 text-sm uppercase tracking-[0.2em] text-gold">
                        Festicloze 2026
                    </p>
                    <h1 class="font-heading text-4xl font-bold text-cream md:text-5xl">
                        Historique
                    </h1>
                    <p class="mt-4 max-w-lg text-cream-muted">
                        Festicloze est né de l'envie de réunir l'élégance de la musique baroque
                        et la magie chaleureuse de Noël. À Montbéliard, le festival propose une
                        expérience immersive où patrimoine musical, lieux emblématiques et esprit
                        festif se rencontrent.
                    </p>
                </div>
                <div class="lg:w-1/2">
                    <img
                        src="/imageaccueil.avif"
                        alt="Festicloze — patrimoine et musique"
                        class="h-64 w-full object-cover object-center lg:h-full lg:min-h-105"
                    />
                </div>
            </div>
        </section>

        <section class="mb-12 rounded-2xl border border-dark-border bg-dark-card p-6 md:p-8">
            <h2 class="mb-5 font-heading text-3xl font-bold text-cream">Le festival</h2>

            <div class="space-y-4 text-cream-muted">
                <p>
                    Inspiré par le raffinement des grands festivals baroques, Festicloze
                    défend une approche plus accessible, plus familiale et plus ouverte
                    au grand public.
                </p>

                <p>
                    Les concerts, les décors lumineux et les cadres architecturaux de la
                    ville composent un rendez-vous culturel pensé pour faire découvrir
                    cette musique autrement.
                </p>

                <p>
                    L’objectif du festival est de proposer un événement à la fois exigeant,
                    convivial et marquant, capable de faire dialoguer la culture, le
                    patrimoine et la période de Noël.
                </p>
            </div>
        </section>

        <section class="mb-12">
            <h2 class="mb-3 font-heading text-3xl font-bold text-cream">L'équipe</h2>

            <p class="mb-10 max-w-3xl text-cream-muted">
                Derrière Festicloze se trouve une équipe passionnée, réunie autour d’une
                vision commune : créer un événement culturel accessible, prestigieux et humain.
            </p>

            <h3 class="mb-5 font-heading text-2xl font-semibold text-cream">Organisateurs</h3>
            <div class="row mb-10">
                {organisateurs.map((membre) => (
                    <article class="col-span-12 md:col-span-6 xl:col-span-3 group overflow-hidden rounded-2xl border border-dark-border bg-dark-card transition-colors hover:border-gold/40">
                        <div class="overflow-hidden">
                            <img
                                src={membre.photo}
                                alt={membre.nom}
                                class="h-52 w-full object-cover object-[50%_30%] transition-transform duration-500 group-hover:scale-105"
                            />
                        </div>
                        <div class="p-5">
                            <h4 class="font-heading text-lg font-semibold text-cream">{membre.nom}</h4>
                            <p class="mt-2 text-sm text-cream-muted">{membre.description}</p>
                        </div>
                    </article>
                ))}
            </div>

            <h3 class="mb-5 font-heading text-2xl font-semibold text-cream">Équipe technique</h3>
            <div class="row">
                {equipeTechnique.map((membre) => (
                    <article class="col-span-12 md:col-span-6 xl:col-span-4 group overflow-hidden rounded-2xl border border-dark-border bg-dark-card transition-colors hover:border-gold/40">
                        <div class="overflow-hidden">
                            <img
                                src={membre.photo}
                                alt={membre.nom}
                                class="h-52 w-full object-cover object-[50%_30%]  transition-transform duration-500 group-hover:scale-105"
                            />
                        </div>
                        <div class="p-5">
                            <h4 class="font-heading text-lg font-semibold text-cream">{membre.nom}</h4>
                            <p class="mt-2 text-sm text-cream-muted">{membre.description}</p>
                        </div>
                    </article>
                ))}
            </div>
        </section>

        <section class="rounded-2xl border border-dark-border bg-dark-card p-6 md:p-8">
            <h2 class="mb-6 font-heading text-3xl font-bold text-cream">Valeurs</h2>

            <div class="row">
                {valeurs.map((valeur) => (
                    <article class="col-span-12 lg:col-span-4 rounded-2xl border border-dark-border bg-dark p-6">
                        <span class="mb-4 block text-2xl text-gold">◆</span>
                        <h3 class="font-heading text-2xl font-semibold text-cream">{valeur.titre}</h3>
                        <p class="mt-4 text-cream-muted">{valeur.texte}</p>
                    </article>
                ))}
            </div>
        </section>
    </main>
</Layout>