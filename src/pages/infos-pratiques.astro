---
import Layout from '../layouts/Layout.astro';

const tarifs = [
    {
        nom: 'Pass 1 jour',
        prix: '25 €',
        description: 'Accès à une journée du festival.'
    },
    {
        nom: 'Pass 2 jours',
        prix: '45 €',
        description: 'Accès à deux journées du festival.'
    },
    {
        nom: 'Pass complet',
        prix: '60 €',
        description: 'Accès à l’ensemble du festival.'
    }
];

const hebergements = [
    {
        nom: 'Hôtel du Centre',
        type: 'Hôtel',
        adresse: '12 rue du Centre, Montbéliard',
        description: 'Hébergement proche du centre-ville et des scènes principales.'
    },
    {
        nom: 'Camping des Lumières',
        type: 'Camping',
        adresse: 'Route du Festival, Montbéliard',
        description: 'Solution économique pour profiter pleinement du festival.'
    },
    {
        nom: 'Auberge de la Gare',
        type: 'Auberge',
        adresse: '5 avenue de la Gare, Montbéliard',
        description: 'Hébergement simple avec accès rapide aux transports.'
    }
];

const transports = [
    {
        titre: 'En train',
        description: 'La gare de Montbéliard permet un accès rapide au centre-ville et aux lieux du festival.'
    },
    {
        titre: 'En voiture',
        description: 'Des parkings sont disponibles à proximité des principales scènes.'
    },
    {
        titre: 'En covoiturage',
        description: 'Le covoiturage est recommandé pour limiter les déplacements individuels.'
    },
    {
        titre: 'Parkings',
        description: 'Des zones de stationnement dédiées sont prévues pour les visiteurs.'
    }
];

const faq = [
    {
        question: 'Faut-il réserver à l’avance ?',
        reponse: 'Oui, il est conseillé de réserver à l’avance pour garantir votre accès aux représentations.'
    },
    {
        question: 'Les billets sont-ils remboursables ?',
        reponse: 'Les billets ne sont pas remboursables, sauf en cas d’annulation d’une représentation.'
    },
    {
        question: 'Peut-on assister à plusieurs concerts dans la même journée ?',
        reponse: 'Oui, selon votre pass et les horaires de programmation.'
    },
    {
        question: 'Le festival est-il accessible en transports en commun ?',
        reponse: 'Oui, plusieurs lieux du festival sont accessibles depuis la gare et les arrêts de bus.'
    }
];
---

<Layout title="Infos pratiques">
    <main class="container py-10">
        <section class="mb-10 overflow-hidden rounded-3xl border border-dark-border bg-dark-card">
            <div class="px-8 py-12 md:px-14">
                <p class="mb-3 text-sm uppercase tracking-[0.2em] text-gold">
                    Festicloze 2026
                </p>

                <h1 class="font-heading text-4xl font-bold text-cream md:text-5xl">
                    Infos pratiques
                </h1>

                <p class="mt-4 max-w-2xl text-cream-muted">
                    Retrouvez les informations utiles pour préparer votre venue au festival :
                    tarifs, hébergements, transports et questions fréquentes.
                </p>
            </div>
        </section>

        <section class="mb-10">
            <h2 class="mb-6 font-heading text-3xl font-bold text-gold">Tarifs</h2>

            <div class="row">
                {tarifs.map((tarif) => (
                    <article class="col-span-12 md:col-span-4 rounded-2xl border border-dark-border bg-dark-card p-6">
                        <h3 class="font-heading text-2xl font-semibold text-cream">{tarif.nom}</h3>
                        <p class="mt-3 font-heading text-3xl font-bold text-gold">{tarif.prix}</p>
                        <p class="mt-3 text-cream-muted">{tarif.description}</p>
                    </article>
                ))}
            </div>
        </section>

        <section class="mb-10">
            <h2 class="mb-6 font-heading text-3xl font-bold text-gold">Hébergements</h2>

            <div class="row">
                {hebergements.map((hebergement) => (
                    <article class="col-span-12 md:col-span-6 xl:col-span-4 rounded-2xl border border-dark-border bg-dark-card p-6">
                        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-gold">{hebergement.type}</p>
                        <h3 class="mt-2 font-heading text-2xl font-semibold text-cream">{hebergement.nom}</h3>
                        <p class="mt-3 text-sm text-cream-muted"><strong class="text-cream">Adresse :</strong> {hebergement.adresse}</p>
                        <p class="mt-3 text-cream-muted">{hebergement.description}</p>
                    </article>
                ))}
            </div>
        </section>

        <section class="mb-10">
            <h2 class="mb-6 font-heading text-3xl font-bold text-gold">Transport</h2>

            <div class="row">
                {transports.map((transport) => (
                    <article class="col-span-12 md:col-span-6 rounded-2xl border border-dark-border bg-dark-card p-6">
                        <h3 class="font-heading text-2xl font-semibold text-cream">{transport.titre}</h3>
                        <p class="mt-3 text-cream-muted">{transport.description}</p>
                    </article>
                ))}
            </div>
        </section>

        <section>
            <h2 class="mb-6 font-heading text-3xl font-bold text-gold">FAQ</h2>

            <div class="space-y-3">
                {faq.map((item, index) => (
                    <article class="overflow-hidden rounded-2xl border border-dark-border bg-dark-card">
                        <button
                            class="faq-button flex w-full items-center justify-between px-6 py-5 text-left"
                            data-index={index}
                        >
                            <span class="font-heading text-lg font-semibold text-cream">{item.question}</span>
                            <span class="faq-icon shrink-0 text-2xl text-gold transition-transform duration-200">+</span>
                        </button>

                        <div class="faq-content hidden px-6 pb-5 text-cream-muted" data-index={index}>
                            {item.reponse}
                        </div>
                    </article>
                ))}
            </div>
        </section>
    </main>

    <script>
        const buttons = document.querySelectorAll<HTMLElement>('.faq-button');

        buttons.forEach((button) => {
            button.addEventListener('click', () => {
                const index   = (button as HTMLElement).dataset.index;
                const content = document.querySelector<HTMLElement>(`.faq-content[data-index="${index}"]`);
                if (!content) return;
                content.classList.toggle('hidden');
                const icon = button.querySelector('.faq-icon');
                if (icon) icon.textContent = content.classList.contains('hidden') ? '+' : '−';
            });
        });
    </script>
</Layout>